# Orkestro Worker Environment Variables

# Master Server bağlantı bilgileri (WebSocket veya HTTP adresi)
MASTER_URL=ws://127.0.0.1:8787

# BullMQ işlemleri için Redis bağlantısı
REDIS_URL=redis://127.0.0.1:6379

# Bu worker için benzersiz ID (otomatik üretilmediyse bunu set edebilirsiniz)
# WORKER_ID=my-remote-worker-1

# Eşzamanlı çalıştırılabilecek maksimum agent sayısı (boş bırakılırsa CPU/RAM kapasitesine göre dinamik ayarlanır)
WORKER_CAPACITY=4

# Bu worker hangi rollerdeki görevleri alabilir? (JSON formatında liste)
WORKER_ROLES=["coder", "planner", "reviewer"]
